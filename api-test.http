# API 测试脚本 - [Gemini]
# 使用说明:
# 1. 安装 VSCode 插件: REST Client (作者: Huachao Mao)
# 2. 修改 @baseUrl 为您的服务器地址
# 3. 首先执行 [1. 登录] 请求，它会自动将 Token 存入变量 {{accessToken}}
# 4. 后续请求会自动携带该 Token 进行鉴权

@baseUrl = http://localhost:3000
@contentType = application/json

###########################################################
### 1. 认证管理 (Auth)
###########################################################

### 1.1 用户登录 (获取 Token)
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "password123"
}

### 提取登录返回的 Token
@accessToken = {{login.response.body.accessToken}}

### 1.2 刷新 Access Token
# 说明: refreshToken 通过 HttpOnly Cookie 自动携带
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

### 1.3 用户登出
POST {{baseUrl}}/api/auth/logout
Content-Type: {{contentType}}


###########################################################
### 2. 硬件查询 (CPU & MB)
###########################################################

### 2.1 组合搜索: 型号模糊 + 核心数精确
GET {{baseUrl}}/api/hw/cpu?keyword=Gold&cores=16
Authorization: Bearer {{accessToken}}

### 2.2 仅搜索型号 (不少于 4 位)
GET {{baseUrl}}/api/hw/cpu?keyword=Epyc
Authorization: Bearer {{accessToken}}

### 2.3 仅搜索核心数 (16 核)
GET {{baseUrl}}/api/hw/cpu?cores=16
Authorization: Bearer {{accessToken}}

### 2.4 根据 cpu_s_name 模糊搜索唯一的 cpu_name 列表
GET {{baseUrl}}/api/hw/cpu/s-name?keyword=Gold
Authorization: Bearer {{accessToken}}

### 2.5 新增 CPU
POST {{baseUrl}}/api/hw/cpu
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "cpu_short_name": "Test CPU 123",
  "cpu_name": "Intel Test Core i99",
  "cores": 128,
  "socket": "LGA9999",
  "tdp": "500W"
}

### 2.5 更新 CPU (需替换 ID)
@cpuHashId = jR8eG9
PUT {{baseUrl}}/api/hw/cpu/{{cpuHashId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "cpu_name": "Intel Test Core i99 Updated",
  "note": "Update test"
}

### 2.6 CPU 详情 (验证 ID 混淆)
# 注意: {{hashId}} 需替换为 2.1 或 2.2 搜索结果中返回的加密 ID (如 jR8eG9)
@hashId = jR8eG9
GET {{baseUrl}}/api/hw/cpu/{{hashId}}
Authorization: Bearer {{accessToken}}

### 2.7 根据关键词搜索主板型号 (不少于 4 位)
GET {{baseUrl}}/api/hw/mb?keyword=X11D
Authorization: Bearer {{accessToken}}

### 2.8 新增主板
POST {{baseUrl}}/api/hw/mb
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "model": "Test MB X999",
  "sockets": "LGA9999",
  "memory_type": "DDR99",
  "url": "http://example.com/mb"
}

### 2.9 更新主板 (需替换 ID)
@mbHashId = jR8eG9
PUT {{baseUrl}}/api/hw/mb/{{mbHashId}}
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "max_tdp": "600W"
}

### 2.10 根据 Socket 查询主板
GET {{baseUrl}}/api/hw/mb/AM5
Authorization: Bearer {{accessToken}}

### 2.11 主板详情 (验证 ID 混淆)
# 注意: {{mbHashId}} 需替换为 2.7 或 2.10 搜索结果中返回的加密 ID (如 jR8eG9)
@mbHashId = jR8eG9
GET {{baseUrl}}/api/hw/mb/detail/{{mbHashId}}
Authorization: Bearer {{accessToken}}


###########################################################
### 3. 服务器信息查询 (SN)
###########################################################

### 3.1 SN 搜索 (不少于 4 位)
GET {{baseUrl}}/api/sn?keyword=R730
Authorization: Bearer {{accessToken}}

### 3.2 根据 CPU 型号查询对应主板型号 (去重反查)
GET {{baseUrl}}/api/sn/cpu2mb/Gold%206248R
Authorization: Bearer {{accessToken}}

### 3.3 检查 SN 唯一性 (存在时 unique: false, 不存在时 true)
GET {{baseUrl}}/api/sn/check-sn/SN20260316001
Authorization: Bearer {{accessToken}}

### 3.4 新增服务器信息 (POST)
POST {{baseUrl}}/api/sn
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "sn": "SN20260316001测试",
  "owner": "Gemini",
  "customer": "Standard Customer",
  "y": 2026,
  "m": 3,
  "d": 16,
  "cpu": "Intel Xeon Gold 6248R",
  "mb": "Supermicro X11DPi-N",
  "mem": "256GB DDR4",
  "os": "Ubuntu 22.04 LTS",
  "note": "Initial deployment test"
}

### 3.4 根据 SN 查询详情 (详情页)
GET {{baseUrl}}/api/sn/SN20260316001
Authorization: Bearer {{accessToken}}


###########################################################
### 4. 仪表盘统计 (Dashboard)
###########################################################

### 4.1 获取汇总统计、最近记录及 OS 分布
GET {{baseUrl}}/api/stats/dashboard
Authorization: Bearer {{accessToken}}
