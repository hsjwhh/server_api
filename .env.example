# ================================
# 应用基础配置
# ================================

# 运行环境：
# 可选值：development / test / production
# 开发环境通常填 development，生产环境通常填 production
NODE_ENV=development

# 后端服务监听端口
# 本地开发常用 3000，生产环境按部署端口填写
PORT=3000

# ID 混淆密钥 (Hashids)
# 必须替换为足够随机的长字符串
# 建议长度不低于 32 个字符
HASHIDS_SALT=replace-with-a-random-salt-string


# ================================
# 前端访问与跨域配置
# ================================

# 前端主地址
# 用于标识默认允许访问后端的前端来源
# 本地联调示例：http://localhost:5173
FRONTEND_URL=http://localhost:5173

# CORS 白名单，支持多个地址，用英文逗号分隔
# 例如：
# CORS_ORIGINS=http://localhost:5173,https://admin.example.com
#
# 如果只配置一个前端地址，通常与 FRONTEND_URL 保持一致即可
CORS_ORIGINS=http://localhost:5173


# ================================
# JWT 鉴权配置
# ================================

# Access Token 签名密钥
# 必填，必须替换成足够长、足够随机的真实密钥
# 不要提交真实值到仓库
JWT_SECRET=replace-with-a-long-random-secret

# Access Token 有效期
# 常见写法：15m / 1h / 2d
JWT_EXPIRES_IN=15m

# Refresh Token 签名密钥
# 必填，建议与 JWT_SECRET 使用不同值
JWT_REFRESH_SECRET=replace-with-another-long-random-secret

# Refresh Token 有效期
# 常见写法：7d / 30d
JWT_REFRESH_EXPIRES_IN=7d

# 单一账号最大并发登录数（顶号逻辑）
# 默认 5 个。如果达到上限，新登录会顶掉最老的一个 Session。
# 设置为 0 表示不限制。
MAX_CONCURRENT_LOGINS=5


# ================================
# Cookie 配置
# ================================

# 是否只允许 HTTPS 下发 Cookie
# 本地开发通常填 false
# 生产环境如果走 HTTPS，建议填 true
COOKIE_SECURE=false

# SameSite 策略
# 可选值：Strict / Lax / None
# 一般前后端同站或常规开发环境用 Lax 即可
# 如果跨站并且需要携带 Cookie，通常要配 None，同时 secure 需为 true
COOKIE_SAME_SITE=Lax

# refreshToken Cookie 过期时间，单位毫秒
# 默认 7 天：7 * 24 * 60 * 60 * 1000 = 604800000
COOKIE_MAX_AGE_MS=604800000

# Cookie 作用域域名
# 留空即可，不要填空格，否则会被当作域名写入 Cookie 导致失效
# 生产环境如需在子域共享 Cookie，可填写如 .example.com
COOKIE_DOMAIN=


# ================================
# MySQL 数据库配置
# ================================

# 数据库主机地址
# 本地开发可填 localhost
# Docker 部署时通常填数据库服务名，例如 mysql
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库用户名
DB_USER=app_user

# 数据库密码
# 必须替换为真实密码，不要提交真实值到仓库
DB_PASSWORD=replace-with-db-password

# 数据库名称
DB_NAME=server_info

# 数据库连接池排队上限
# 连接池满时请求的最大排队数量
# 0 表示不限制（请求会一直等待，不会直接报错）
DB_QUEUE_LIMIT=0

# 连接池最大连接数，默认 10
# 生产环境可根据并发量适当调大，如 20~50
DB_CONNECTION_LIMIT=10


# ================================
# MinIO / S3 对象存储配置
# ================================

# MinIO 服务内网地址（含协议和端口，不带末尾斜杠）
# Docker 容器内通常用容器名，如 http://minio:9000
MINIO_ENDPOINT=http://minio:9000

# Access Key
MINIO_ACCESS_KEY=replace-with-access-key

# Secret Key
MINIO_SECRET_KEY=replace-with-secret-key

# Bucket 名称
MINIO_BUCKET=your-bucket-name

# 存储区域（MinIO 通常填 us-east-1）
MINIO_REGION=us-east-1
